# World Globe — Icon, Texture & Video Pattern

## Files involved
- `src/components/WorldGlobe.tsx` — all globe logic lives here
- `public/` — all images and icons must be copied here for Three.js to access them
- `src/assets/images/` — original source images (not directly usable by Three.js)

---

## Step 1 — Copy icon to public/
```powershell
Copy-Item "src\assets\images\My World Icon.png" "public\my-world-icon.png"
```
Use lowercase-kebab filenames: `fossil-frontier-icon.png`, `aqua-azul-icon.png`

---

## Step 2 — Create a textured globe component (matches Aqua Azul / Fossil Frontier pattern)

```tsx
function MyWorldIslandTexture({ size }: { size: number }) {
  const texture = useTexture("/my-world-icon.png");
  const sphereRef = useRef<THREE.Mesh>(null);

  useFrame((s) => {
    if (sphereRef.current) {
      sphereRef.current.rotation.y = s.clock.elapsedTime * 0.1;
    }
  });

  return (
    <group>
      <mesh ref={sphereRef} position={[0, -size * 0.1, 0]}>
        <sphereGeometry args={[size * 0.75, 48, 48]} />
        <meshStandardMaterial map={texture} roughness={0.6} metalness={0.1} />
      </mesh>

      {/* Glow ring — use the world's accent color */}
      <Torus args={[size * 0.82, size * 0.022, 8, 48]} rotation={[Math.PI / 2, 0, 0]} position={[0, -size * 0.55, 0]}>
        <meshStandardMaterial color="#ACCENT" emissive="#COLOR" emissiveIntensity={1.4} transparent opacity={0.65} />
      </Torus>

      {/* 3 floating particles */}
      {[0.55, -0.55, 0].map((x, i) => (
        <Float key={i} speed={2 + i} floatIntensity={0.5}>
          <Sphere args={[size * 0.04, 8, 8]} position={[x * size, size * (0.7 + i * 0.15), 0]}>
            <meshStandardMaterial color="#PARTICLE_COLOR" transparent opacity={0.55} />
          </Sphere>
        </Float>
      ))}
    </group>
  );
}

function MyWorldIsland({ size }: { size: number }) {
  return (
    <React.Suspense fallback={
      <Sphere args={[size * 0.75, 16, 16]} position={[0, -size * 0.1, 0]}>
        <meshStandardMaterial color="#FALLBACK_COLOR" />
      </Sphere>
    }>
      <MyWorldIslandTexture size={size} />
    </React.Suspense>
  );
}
```

---

## Step 3 — Register in IslandMesh map

```tsx
const meshMap: Record<string, ...> = {
  "My World Title": MyWorldIsland,
  // ...existing worlds
};
```

