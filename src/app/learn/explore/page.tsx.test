                      const unitIndex = index;
                      const isCurrentUnit =
                        unitIndex === currentUnitProgress.currentUnit;
                      const themeColor =
                        UNIT_COLORS[unitIndex % UNIT_COLORS.length];

                      let stepsForUnit: UnitStepStatus[];
                      let completedCountForUnit = 0;

                      if (unitIndex < currentUnitProgress.currentUnit) {
                        stepsForUnit = UNIT_STEP_ORDER.map(() => "completed");
                        completedCountForUnit = UNIT_STEP_ORDER.length;
                      } else if (isCurrentUnit) {
                        stepsForUnit = currentUnitSteps;
                        completedCountForUnit = currentUnitProgress.currentStep;
                      } else {
                        stepsForUnit = UNIT_STEP_ORDER.map(() => "locked");
                        completedCountForUnit = 0;
                      }

                      const cardShadow = isCurrentUnit
                        ? "0 10px 24px rgba(37,99,235,0.12)"
                        : "0 6px 16px rgba(15,23,42,0.05)";

                      const borderColor = isCurrentUnit
                        ? "rgba(59,130,246,0.45)"
                        : "rgba(226,232,240,0.9)";

                      const backgroundGradient = isCurrentUnit
                        ? "linear-gradient(180deg,rgba(239,246,255,0.9),#ffffff)"
                        : "#ffffff";

                      const statusLabel = isCurrentUnit
                        ? "Current unit"
                        : unitIndex < currentUnitProgress.currentUnit
                          ? "Completed"
                          : "Locked";

                      const rewardLabel = isCurrentUnit
                        ? "Reward: 10 XP"
                        : unitIndex < currentUnitProgress.currentUnit
                          ? "Reward: 10 XP + 1 chest"
                          : "Locked Â· finish earlier units";

                      return (
                        <div
                          key={unitIndex}
                          style={{
                            position: "relative",
                            borderRadius: "0.95rem",
                            border: `1px solid ${borderColor}`,
                            background: backgroundGradient,
                            boxShadow: cardShadow,
                            padding: "0.8rem 0.9rem 0.85rem",
                            transform: isCurrentUnit
                              ? "translateY(-2px)"
                              : "translateY(0)",
                            transition:
                              "transform 160ms ease-out, box-shadow 160ms ease-out",
                            overflow: "hidden",
                            cursor: isCurrentUnit ? "pointer" : "default",
                          }}
                          onClick={() => {
                            if (!isCurrentUnit) return;

                            const stepKind =
                              UNIT_STEP_ORDER[currentUnitProgress.currentStep];
                            const dbUnitId = activeUnits[unitIndex]?.id;

                            void launchExternalLesson(
                              unitIndex,
                              stepKind,
                              dbUnitId,
                            );
                          }}
                        >
                          <CardBackgroundArt
                            src={
                              isCurrentUnit
                                ? MISSION_CARD_BACKGROUNDS.active
                                : MISSION_CARD_BACKGROUNDS.locked
                            }
                            opacity={isCurrentUnit ? 0.16 : 0.1}
                          />
                          <div
                            style={{
                              position: "absolute",
                              inset: 0,
                              background:
                                "linear-gradient(160deg, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0.92) 100%)",
                              pointerEvents: "none",
                              zIndex: 1,
                            }}
                          />
                          <div
                            style={{
                              position: "relative",
                              zIndex: 2,
                              display: "flex",
                              justifyContent: "space-between",
                              alignItems: "center",
                              gap: "0.75rem",
                              marginBottom: "0.45rem",
                            }}
                          >
                            <div
                              style={{
                                display: "flex",
                                flexDirection: "column",
                                gap: "0.12rem",
                              }}
                            >
                              <span
                                style={{
                                  fontSize: "0.66rem",
                                  textTransform: "uppercase",
                                  letterSpacing: "0.08em",
                                  color: "#64748b",
                                  fontWeight: 700,
                                }}
                              >
                                Section {activeSection.id} · Unit{" "}
                                {unitIndex + 1}
                              </span>
                              <span
                                className="font-fredoka"
                                style={{
                                  fontSize: "1.02rem",
                                  fontWeight: 700,
                                  color: "#111827",
                                  lineHeight: 1.25,
                                }}
                              >
                                {unitTitle}
                              </span>
                              <span
                                style={{
                                  fontSize: "0.7rem",
                                  color: "#64748b",
                                  fontWeight: 600,
                                }}
                              >
                                {rewardLabel}
                              </span>
                            </div>
                            <div
                              style={{
                                display: "flex",
                                alignItems: "center",
                                gap: "0.4rem",
                              }}
                            >
                              {unitIndex < currentUnitProgress.currentUnit && (
                                <div
                                  style={{
                                    width: 22,
                                    height: 22,
                                    borderRadius: "999px",
                                    background: themeColor,
                                    display: "flex",
                                    alignItems: "center",
                                    justifyContent: "center",
                                    boxShadow:
                                      "0 0 0 2px rgba(255,255,255,0.9), 0 6px 12px rgba(15,23,42,0.35)",
                                    fontSize: "0.75rem",
                                    color: "#f9fafb",
                                    fontWeight: 800,
                                  }}
                                >
                                  â
                                </div>
                              )}
                              <span
                                style={{
                                  padding: "0.2rem 0.5rem",
                                  borderRadius: "0.5rem",
                                  fontSize: "0.63rem",
                                  fontWeight: 700,
                                  background: isCurrentUnit
                                    ? "#1d4ed8"
                                    : "#f1f5f9",
                                  color: isCurrentUnit ? "#f9fafb" : "#4b5563",
                                  letterSpacing: "0.04em",
                                  textTransform: "uppercase",
                                }}
                              >
                                {statusLabel}
                              </span>
                            </div>
                          </div>

                          <div style={{ position: "relative", zIndex: 2 }}>
                            <ExploreDuolingoPath
                              steps={stepsForUnit}
                              themeColor={themeColor}
                              currentCount={completedCountForUnit}
                              onStepClick={(stepIndex) => {
                                if (!isCurrentUnit) return;
                                const stepKind = UNIT_STEP_ORDER[stepIndex];
                                const dbUnitId = activeUnits[unitIndex]?.id;
                                void launchExternalLesson(
                                  unitIndex,
                                  stepKind,
                                  dbUnitId,
                                );
                              }}
                            />
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </motion.div>

                {/* Hero card + current unit details */}
                <div
                  style={{
                    marginTop: "0.6rem",
                    marginBottom: "0.45rem",
                    alignSelf: "stretch",
                    borderRadius: "1rem",
                    background: "#ffffff",
                    border: "1px solid #e2e8f0",
                    padding: "0.85rem 0.95rem",
                    display: "flex",
                    alignItems: "center",
                    justifyContent: "space-between",
                    gap: "0.9rem",
                    boxShadow: "0 8px 20px rgba(15,23,42,0.06)",
                  }}
                >
                  <div style={{ flex: 1 }}>
                    <p
                      style={{
                        fontSize: "0.68rem",
                        color: "#64748b",
                        marginBottom: "0.25rem",
                        textTransform: "uppercase",
                        letterSpacing: "0.08em",
                        fontWeight: 700,
                      }}
                    >
                      Next up
                    </p>
                    <p
                      className="font-fredoka"
                      style={{
                        fontSize: "1.08rem",
                        fontWeight: 700,
                        color: "#111827",
