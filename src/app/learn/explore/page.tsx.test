                  animate={{ opacity: 1, y: 0 }}
                  style={{
                    borderRadius: "1.2rem",
                    padding: "1.15rem 1.25rem",
                    background: `linear-gradient(135deg, ${EXPLORE.green} 0%, ${EXPLORE.sky} 100%)`,
                    color: "#fff",
                    boxShadow: `0 5px 0 ${EXPLORE.greenDark}, 0 16px 32px rgba(88,204,2,0.22)`,
                  }}
                >
                  <p
                    className="font-fredoka"
                    style={{
                      fontSize: "1.5rem",
                      fontWeight: 400,
                      marginBottom: "0.35rem",
                      lineHeight: 1.2,
