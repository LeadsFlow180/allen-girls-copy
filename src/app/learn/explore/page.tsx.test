                  >
                    Your learning path
                  </p>
                  <p
                    className="font-nunito"
                    style={{
                      fontSize: "0.9rem",
                      opacity: 0.95,
                      fontWeight: 600,
                      lineHeight: 1.5,
                      maxWidth: "34rem",
                      margin: 0,
                    }}
                  >
                    Pick a section, follow the zigzag missions, and earn XP 
                    just like your favorite language app.
                  </p>
                </motion.div>
                {sectionsData.map((section) => (
                  <ExploreSectionCard
                    key={section.id}
                    sectionId={section.id}
                    title={section.title}
                    bubble={section.bubble}
                    description={section.description}
                    icon={section.icon}
                    progress={section.progress}
                    isActive={section.id === activeSectionId}
                    onContinue={() => {
                      setActiveSectionId(section.id);
                      setShowUnitView(true);
                    }}
                  />
                ))}
              </motion.div>
            )}

            {showUnitView && (
              <section
                className="font-nunito"
                style={{
                  borderRadius: "1.35rem",
                  padding: "0 0 1.2rem",
                  background: EXPLORE.card,
                  boxShadow: `0 5px 0 #d1d5db, 0 18px 40px rgba(15,23,42,0.08)`,
                  border: `2px solid ${EXPLORE.greenLight}`,
                  display: "flex",
                  flexDirection: "column",
                  alignItems: "stretch",
                  gap: "0.85rem",
                  overflow: "hidden",
                }}
              >
                {/* Section header */}
                <div
                  style={{
                    alignSelf: "stretch",
                    background: `linear-gradient(90deg, ${EXPLORE.green}, ${EXPLORE.sky})`,
