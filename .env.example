# Allen Girls Adventures — copy this file to `.env.local` and fill in values.
# Never commit `.env.local` (it stays on your machine only).

# Anthropic Claude API (server-side only — do not prefix with NEXT_PUBLIC_)
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-4-20250514 in src/lib/ai/claude.ts
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Supabase (Phase 1 — auth + profiles + placement cloud save)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server writes + guardian-created child accounts (POST /api/parent/children)
# Required for parents to create verified learner logins from Family profiles.
# SUPABASE_SERVICE_ROLE_KEY=

# Learn pages (explore, courses) use bundled demo data unless this is true:
# NEXT_PUBLIC_LEARN_USE_SUPABASE=true

# Server /api/learn/* auth (redirect, course-view) — off by default:
# SUPABASE_SERVER_AUTH=true

# External lesson redirect (AI School)
# AI_SCHOOL_SITE_URL=https://your-ai-school-host
# AI_SCHOOL_REDIRECT_SECRET=
# AI_SCHOOL_DEFAULT_CLASSROOM_ID=l4gHC6hvRo
# NEXT_PUBLIC_LEARN_CLASSROOM_ID=l4gHC6hvRo
